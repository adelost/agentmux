{
  "name": "agentmux",
  "version": "1.24.2",
  "description": "Local bridge and native workspace for coding agents (Claude Code, Codex)",
  "type": "module",
  "bin": {
    "amux": "./bin/agent-cli.mjs",
    "ax": "./bin/agent-cli.mjs"
  },
  "scripts": {
    "setup": "bash bin/setup.sh",
    "start": "node index.mjs",
    "dev": "bash bin/start.sh",
    "ci": "npm test -- --maxWorkers=1 && npm run test:ci-contract",
    "test": "vitest run",
    "test:ci-contract": "node docs/check-ci-contract.mjs",
    "test:webui:visual": "node spikes/web-ui/tools/visual-gate.mjs",
    "test:webui:native-canary": "node spikes/web-ui/tools/native-canary-gate.mjs"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "discord.js": "^14.18.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@openai/codex": "0.144.4",
    "bdd-vitest": "^2.0.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
