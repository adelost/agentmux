{
  "name": "agentmux",
  "version": "1.25.17",
  "description": "Local bridge and native workspace for coding agents (Claude Code, Codex, Kimi Code)",
  "type": "module",
  "bin": {
    "amux": "./bin/agent-cli.mjs",
    "ax": "./bin/agent-cli.mjs",
    "amux-suggest": "./bin/amux-suggest.mjs",
    "overlap-gate": "./bin/overlap-gate.mjs"
  },
  "scripts": {
    "setup": "bash bin/setup.sh",
    "start": "node --import ./bin/quota-recovery-bootstrap.mjs index.mjs",
    "dev": "bash bin/start.sh",
    "ci": "npm test && npm run test:ci-contract",
    "test": "vitest run",
    "test:ci-contract": "node docs/check-ci-contract.mjs",
    "test:webui:visual": "node spikes/web-ui/tools/visual-gate.mjs",
    "test:webui:native-canary": "node spikes/web-ui/tools/native-canary-gate.mjs",
    "test:webui:claude-process-canary": "node spikes/web-ui/tools/claude-persistent-process-canary.mjs"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "discord.js": "^14.18.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@openai/codex": "0.144.4",
    "bdd-vitest": "^2.0.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
