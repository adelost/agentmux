#!/bin/bash
# agent — Minimal tmux agent CLI for Agentus (send + wait only)
# Full version: https://github.com/adelost/openclaw scripts/agent

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
EXTRACT_BIN="$SCRIPT_DIR/extract-text.mjs"

SOCKET="${TMUX_SOCKET:-/tmp/agentus-tmux.sock}"
CONFIG="${AGENTS_YAML:-$SCRIPT_DIR/../agents.yaml}"
CLAUDE_FLAGS="--dangerously-skip-permissions"

# --- YAML helpers (requires yq + jq) ---

ensure_config() {
  if [[ ! -f "$CONFIG" ]]; then
    echo "Config not found: $CONFIG" >&2
    echo "Copy agents.yaml.example to agents.yaml and configure your agents." >&2
    return 1
  fi
}

get_agent() {
  local name="$1"
  local has_agent
  has_agent=$(yq ".[\"$name\"] | has(\"dir\")" "$CONFIG" 2>/dev/null)
  if [[ "$has_agent" != "true" ]]; then
    echo "Agent '$name' not found in $CONFIG" >&2
    return 1
  fi
  yq -o=json ".[\"$name\"]" "$CONFIG"
}

get_dir()        { echo "$1" | jq -r '.dir'; }
get_id()         { echo "$1" | jq -r '.id'; }
get_pane_count() { yq ".[\"$1\"].panes | length" "$CONFIG" 2>/dev/null || echo "0"; }
get_pane_cmd()   { yq ".[\"$1\"].panes[$2].cmd // \"bash\"" "$CONFIG" 2>/dev/null; }
get_pane_name()  { yq ".[\"$1\"].panes[$2].name // \"pane-$2\"" "$CONFIG" 2>/dev/null; }
is_pane_deferred() { yq ".[\"$1\"].panes[$2].defer // false" "$CONFIG" 2>/dev/null; }
get_layout()     { yq ".[\"$1\"].layout // \"main-vertical\"" "$CONFIG" 2>/dev/null; }

# --- tmux helpers ---

exit_copy_mode() {
  local target="$1"
  if tmux -S "$SOCKET" display-message -t "$target" -p '#{pane_in_mode}' 2>/dev/null | grep -q '1'; then
    tmux -S "$SOCKET" send-keys -t "$target" q 2>/dev/null
    sleep 0.3
  fi
}

extract_response() {
  local target="$1"
  local max_lines="${2:-200}"
  (
    set +o pipefail
    tmux -S "$SOCKET" capture-pane -t "$target" -p -J -S -5000 2>/dev/null \
      | node "$EXTRACT_BIN" \
      | head -"$max_lines"
  )
}

extract_tail() {
  local target="$1"
  local lines="${2:-20}"
  (
    set +o pipefail
    tmux -S "$SOCKET" capture-pane -t "$target" -p -J -S -5000 2>/dev/null \
      | tail -"$lines"
  )
}

MIN_WINDOW_WIDTH=300
MIN_WINDOW_HEIGHT=80

ensure_tmux() {
  if ! tmux -S "$SOCKET" has-session -t "$1" 2>/dev/null; then
    tmux -S "$SOCKET" new-session -d -s "$1"
    tmux -S "$SOCKET" source-file ~/.tmux.conf 2>/dev/null || true
    tmux -S "$SOCKET" set-option -g window-size largest 2>/dev/null || true
  fi
  # Ensure minimum window size
  local cur_w cur_h
  cur_w=$(tmux -S "$SOCKET" display -t "$1" -p '#{window_width}' 2>/dev/null) || return
  cur_h=$(tmux -S "$SOCKET" display -t "$1" -p '#{window_height}' 2>/dev/null) || return
  if [[ "$cur_w" -lt "$MIN_WINDOW_WIDTH" || "$cur_h" -lt "$MIN_WINDOW_HEIGHT" ]]; then
    local new_w=$((cur_w > MIN_WINDOW_WIDTH ? cur_w : MIN_WINDOW_WIDTH))
    local new_h=$((cur_h > MIN_WINDOW_HEIGHT ? cur_h : MIN_WINDOW_HEIGHT))
    tmux -S "$SOCKET" resize-window -t "$1" -x "$new_w" -y "$new_h" 2>/dev/null || true
  fi
}

setup_panes() {
  local name="$1" dir="$2"
  local pane_count
  pane_count=$(get_pane_count "$name")

  if [[ "$pane_count" == "0" || "$pane_count" == "null" ]]; then
    start_claude "$name" "${name}:.0" "$dir" "$(get_id "$(get_agent "$name")")"
    return
  fi

  local existing_panes
  existing_panes=$(tmux -S "$SOCKET" list-panes -t "$name" 2>/dev/null | wc -l)

  for ((i = existing_panes; i < pane_count; i++)); do
    tmux -S "$SOCKET" split-window -t "$name" -h 2>/dev/null || true
  done

  local layout
  layout=$(get_layout "$name")
  tmux -S "$SOCKET" select-layout -t "$name" "$layout" 2>/dev/null || true

  for ((i = 0; i < pane_count; i++)); do
    local target="${name}:.${i}"
    local pane_cmd pane_defer current_cmd

    pane_cmd=$(get_pane_cmd "$name" "$i")
    pane_defer=$(is_pane_deferred "$name" "$i")

    current_cmd=$(tmux -S "$SOCKET" display-message -t "$target" -p '#{pane_current_command}' 2>/dev/null || echo "")
    if [[ "$current_cmd" == *"claude"* || "$current_cmd" == *"node"* || "$current_cmd" == *"make"* || "$current_cmd" == *"vite"* || "$current_cmd" == *"python"* ]]; then
      continue
    fi

    if [[ "$pane_defer" == "true" ]]; then
      tmux -S "$SOCKET" send-keys -t "$target" "cd $dir" Enter
    else
      tmux -S "$SOCKET" send-keys -t "$target" "cd $dir && $pane_cmd" Enter
    fi
    sleep 0.5
  done

  tmux -S "$SOCKET" select-pane -t "${name}:.0" 2>/dev/null || true
}

start_claude() {
  local name="$1" target="$2" dir="$3" id="$4"

  local encoded_dir
  encoded_dir=$(echo "$dir" | sed 's|/|-|g')
  local session_flag="--session-id $id"
  if ls "$HOME/.claude/projects/$encoded_dir/"*.jsonl >/dev/null 2>&1; then
    session_flag="--continue"
  fi
  local cmd="cd $dir && claude $CLAUDE_FLAGS $session_flag"

  local pane_dead
  pane_dead=$(tmux -S "$SOCKET" display-message -t "$target" -p '#{pane_dead}' 2>/dev/null || echo "0")
  if [[ "$pane_dead" == "1" ]]; then
    tmux -S "$SOCKET" respawn-pane -t "$target" -k 2>/dev/null || true
    sleep 0.5
  fi

  local pane_cmd
  pane_cmd=$(tmux -S "$SOCKET" display-message -t "$target" -p '#{pane_current_command}' 2>/dev/null || echo "")
  if [[ "$pane_cmd" == *"claude"* || "$pane_cmd" == *"node"* ]]; then
    return 0
  fi

  tmux -S "$SOCKET" send-keys -t "$target" "$cmd" Enter
  sleep 2
}

# --- Commands ---

cmd_send() {
  local name="$1" prompt="$2" pane="${3:-0}"

  local agent
  agent=$(get_agent "$name")
  local dir
  dir=$(get_dir "$agent")

  local is_new=false
  if ! tmux -S "$SOCKET" has-session -t "$name" 2>/dev/null; then
    is_new=true
  fi

  ensure_tmux "$name"

  if [[ "$is_new" == true ]]; then
    setup_panes "$name" "$dir"
    sleep 2
  fi

  local target="${name}:.${pane}"

  local pane_cmd_yaml
  pane_cmd_yaml=$(get_pane_cmd "$name" "$pane")
  if [[ "$pane_cmd_yaml" == *"claude"* ]]; then
    local id
    id=$(get_id "$agent")
    start_claude "$name" "$target" "$dir" "$id"
  fi

  local pane_cmd
  pane_cmd=$(tmux -S "$SOCKET" display-message -t "$target" -p '#{pane_current_command}' 2>/dev/null || echo "")
  if [[ "$pane_cmd" != *"claude"* && "$pane_cmd" != *"node"* ]]; then
    for i in $(seq 1 20); do
      sleep 0.5
      pane_cmd=$(tmux -S "$SOCKET" display-message -t "$target" -p '#{pane_current_command}' 2>/dev/null || echo "")
      if [[ "$pane_cmd" == *"claude"* || "$pane_cmd" == *"node"* ]]; then
        sleep 1
        break
      fi
    done
  fi

  exit_copy_mode "$target"

  if [[ ${#prompt} -gt 500 ]]; then
    local prompt_file="/tmp/agent-prompt-$$.txt"
    printf '%s' "$prompt" > "$prompt_file"
    local buf_name="prompt_$$_$(date +%s)"
    tmux -S "$SOCKET" load-buffer -b "$buf_name" "$prompt_file" 2>/dev/null
    tmux -S "$SOCKET" paste-buffer -b "$buf_name" -t "$target" 2>/dev/null
    rm -f "$prompt_file"
    sleep 5
  else
    tmux -S "$SOCKET" send-keys -t "$target" -l -- "$prompt"
    sleep 1
  fi
  tmux -S "$SOCKET" send-keys -t "$target" Enter
  echo "Sent to '$name' (pane $pane): $prompt"
}

cmd_wait() {
  local name="$1" pane="${2:-0}" timeout="${3:-300}"
  local target="${name}:.${pane}"

  get_agent "$name" >/dev/null

  if ! tmux -S "$SOCKET" has-session -t "$name" 2>/dev/null; then
    echo "No tmux session for '$name'." >&2
    return 1
  fi

  local elapsed=0 interval=2 saw_working=false gone=0

  # Check initial state
  exit_copy_mode "$target"
  local init_screen
  init_screen=$(tmux -S "$SOCKET" capture-pane -t "$target" -p -S -10 2>/dev/null || echo "")
  if echo "$init_screen" | grep -qE 'esc to interrupt|Enter to select|Esc to cancel|Allow once|Allow always|Do you want to proceed'; then
    saw_working=true
  else
    sleep 2
    init_screen=$(tmux -S "$SOCKET" capture-pane -t "$target" -p -S -10 2>/dev/null || echo "")
    if echo "$init_screen" | grep -qE 'esc to interrupt|Enter to select|Esc to cancel|Allow once|Allow always|Do you want to proceed'; then
      saw_working=true
    else
      echo "idle"
      return 0
    fi
  fi

  while [[ $elapsed -lt $timeout ]]; do
    exit_copy_mode "$target"
    local screen
    screen=$(tmux -S "$SOCKET" capture-pane -t "$target" -p -S -10 2>/dev/null || echo "")

    local state="unknown"
    if echo "$screen" | grep -q 'esc to interrupt'; then
      state="working"; saw_working=true
    elif echo "$screen" | grep -qE 'Enter to select|Esc to cancel'; then
      state="menu"
    elif echo "$screen" | grep -qE 'Allow once|Allow always|Do you want to proceed'; then
      state="permission"
    fi

    if [[ "$state" == "menu" ]] && [[ "$saw_working" == true || $elapsed -ge 4 ]]; then
      echo "menu"; return 2
    fi
    if [[ "$state" == "permission" ]] && [[ "$saw_working" == true || $elapsed -ge 4 ]]; then
      echo "permission"; return 3
    fi

    if [[ "$saw_working" == true && "$state" != "working" ]]; then
      gone=$((gone + interval))
      if [[ $gone -ge 2 ]]; then
        echo "ready"; return 0
      fi
    else
      gone=0
    fi
    sleep "$interval"
    elapsed=$((elapsed + interval))
  done
  echo "timeout"; return 1
}

# --- Dispatch ---

ensure_config

QUIET=false
PANE=0

case "${1:-}" in
  wait)
    shift
    NAME="$1"; shift
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -t) TIMEOUT="$2"; shift 2 ;;
        -p) PANE="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    cmd_wait "$NAME" "$PANE" "${TIMEOUT:-300}"
    ;;
  *)
    NAME="$1"; shift
    PROMPT="$1"; shift || true
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -q) QUIET=true; shift ;;
        -p) PANE="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [[ -z "${PROMPT:-}" ]]; then
      echo "Usage: agent <name> <prompt> [-q] [-p pane]" >&2
      exit 1
    fi
    cmd_send "$NAME" "$PROMPT" "$PANE"
    ;;
esac
