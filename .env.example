# Required
DISCORD_TOKEN=

# Optional — all have sane defaults

# Tmux socket path (default: /tmp/agentmux-tmux.sock)
# TMUX_SOCKET=/tmp/agentmux.sock

# Path to agentmux.yaml config (default: ./agentmux.yaml)
# AGENTMUX_YAML=/path/to/agentmux.yaml

# Path to generated agents.yaml (default: ./agents.yaml)
# AGENTS_YAML=/path/to/agents.yaml

# Max wait for agent response in seconds (default: 600)
# TIMEOUT_S=600

# Text-to-speech voice (default: sv-SE-MattiasNeural)
# TTS_VOICE=sv-SE-MattiasNeural

# Enable TTS on startup (default: 0)
# TTS=0

# OpenAI API key (for Whisper transcription of voice messages)
# OPENAI_API_KEY=
