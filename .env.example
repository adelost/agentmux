# Required
DISCORD_TOKEN=

# Optional — all have sane defaults

# Tmux socket path (default: /tmp/agentus-tmux.sock)
# TMUX_SOCKET=/tmp/agentus-tmux.sock

# Path to agents.yaml (default: ./agents.yaml)
# AGENTS_YAML=/path/to/agents.yaml

# Max wait for agent response in seconds (default: 600)
# TIMEOUT_S=600

# Text-to-speech voice (default: sv-SE-MattiasNeural)
# TTS_VOICE=sv-SE-MattiasNeural

# Enable TTS on startup (default: 0)
# TTS=0

# Whisper endpoint for voice messages (default: http://localhost:2022/v1/audio/transcriptions)
# WHISPER_URL=http://localhost:2022/v1/audio/transcriptions

# OpenAI API key (for Whisper transcription via bundled script)
# OPENAI_API_KEY=
