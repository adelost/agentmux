# Suggestions quota push: sends the local weekly-quota snapshot (Claude +
# Codex) to the board so the authority owner sees a quota hint there.
# Copy to ~/.config/agent/suggestions-quota-push.yaml.
baseUrl: https://suggest.v1d.io
adminCredentialFile: ~/.config/agent/suggestions-admin-token

# Optional context telemetry settings. Context uses the same local admin
# credential but a separate endpoint, state file, cadence and UI semantics.
contextFleetConfigFile: ~/.agentmux/fleet-watch/fleets.conf
contextEventsFile: ~/.agentmux/events.jsonl
contextStateFile: ~/.agentmux/suggestions-context-push-state.json
contextHeartbeatMs: 300000
