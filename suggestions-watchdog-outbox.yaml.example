# Persistent watchdog delivery for every public project visible to this token.
baseUrl: https://suggest.v1d.io
discoveryProject: source

# By default the project registry is discovered on every run. Set a bounded
# explicit override only when intentionally limiting delivery:
# projects:
#   - source
#   - skydive

# Both files must be regular, current-user-owned, mode 0600, and one line.
readCredentialFile: ~/.config/agent/suggestions-read-token
adminCredentialFile: ~/.config/agent/suggestions-admin-token

requestTimeoutMs: 15000
deliveryWaitMs: 12000
